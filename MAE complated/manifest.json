{
  "manifest_version": 3,
  "name": "Meesho Supplier Panel Auto-Fill",
  "version": "1.0.0",
  "description": "Auto-fill Meesho supplier panel forms by fetching data from Google Sheets using Marke Number",
  "author": "Your Name",
  
  "permissions": [
    "activeTab",
  "scripting",
  "storage",
  "tabs",
  "notifications"
  ],
  
  "host_permissions": [
    "https://supplier.meesho.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://supplier.meesho.com/*",
        "https://supplier.meesho.com/panel/*",
        "https://supplier.meesho.com/panel/v3/new/cataloging/g4v6e/catalogs/single/add*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["config.js"],
      "matches": ["https://supplier.meesho.com/*"]
    }
  ]
}
